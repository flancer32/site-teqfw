# TeqFW built-in web server runtime configuration.
TEQFW_WEB_SERVER_PORT=3000
TEQFW_WEB_SERVER_TYPE=http

# TLS values are required only for https mode.
# TEQFW_WEB_SERVER_TLS_CA=/absolute/path/to/ca.pem
# TEQFW_WEB_SERVER_TLS_CERT=/absolute/path/to/cert.pem
# TEQFW_WEB_SERVER_TLS_KEY=/absolute/path/to/key.pem
