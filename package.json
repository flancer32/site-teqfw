{
  "name": "@flancer32/site-teqfw",
  "version": "0.1.0",
  "description": "Server-side rendered website application for the ADSM and TeqFW author ecosystem (teqfw.com).",
  "type": "module",
  "license": "Apache-2.0",
  "author": {
    "name": "Alex Gusev",
    "email": "alex@flancer64.com",
    "url": "https://github.com/flancer64"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flancer32/site-teqfw.git"
  },
  "homepage": "https://github.com/flancer32/site-teqfw",
  "bugs": {
    "url": "https://github.com/flancer32/site-teqfw/issues"
  },
  "keywords": [
    "teqfw",
    "adsm",
    "tequila-framework",
    "website",
    "ssr",
    "nodejs",
    "dependency-injection",
    "llm-agents"
  ],
  "types": "types.d.ts",
  "scripts": {
    "start": "node ./bin/bootstrap.mjs",
    "test:unit": "find test/unit -name '*.test.mjs' -print0 | xargs -0 node --test",
    "test:integration": "find test/integration -name '*.test.mjs' -print0 | xargs -0 node --test",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "@flancer32/teq-web": "^0.11.0",
    "@teqfw/di": ">=2.5.1 <3.0.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.2"
  },
  "engines": {
    "node": ">=20"
  },
  "teqfw": {
    "namespaces": [
      {
        "prefix": "TeqFw_Site_",
        "path": "./src",
        "ext": ".mjs"
      }
    ]
  }
}
